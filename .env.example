# THESIS operator env — never commit real secrets

# Engine
THESIS_CORS=*

# Deploy (prefer Foundry keystore over raw key)
PRIVATE_KEY=0xYOUR_TESTNET_KEY
DEPLOYER_OWNER=0xYOUR_ADDRESS
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC_URL=https://rpc.monad.xyz

# Web build
VITE_API_URL=http://127.0.0.1:8043
